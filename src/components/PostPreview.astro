---
interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  minutesRead?: number;
}

const { slug, title, description, date, tags, minutesRead } = Astro.props;

const dateStr = date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<a
  href={`/blog/${slug}/`}
  class="group block border border-[var(--border)] rounded-lg p-5 mb-3 hover:bg-[var(--surface-hover)] transition-all duration-150"
>
  <div class="flex items-center justify-between gap-3 mb-2 font-mono text-[13px] text-[var(--text-tertiary)]">
    <time datetime={date.toISOString()}>{dateStr}</time>
    {minutesRead && <span>{minutesRead} min</span>}
  </div>
  <h2 class="font-mono text-[17px] font-medium text-[var(--text-primary)] leading-snug mb-1.5 group-hover:text-[var(--accent)] transition-colors duration-150">
    {title}
  </h2>
  <p class="text-[14px] text-[var(--text-secondary)] leading-relaxed mb-3">
    {description}
  </p>
  <div class="flex flex-wrap gap-1.5">
    {tags.slice(0, 3).map((tag) => (
      <span class="font-mono text-[12px] bg-[var(--surface)] text-[var(--text-tertiary)] px-2 py-0.5 rounded">
        {tag}
      </span>
    ))}
  </div>
</a>
