---
const links = [
  { label: 'GitHub',  href: 'https://github.com/mkappworks-dev',  icon: 'github' },
  { label: 'X',       href: 'https://www.x.com/mkappworks',        icon: 'x' },
  { label: 'Discord', href: 'https://discord.gg/g2xKWJcF',         icon: 'discord' },
  { label: 'YouTube', href: 'https://youtube.com/@mkappworks',     icon: 'youtube' },
];
---

<div class="flex items-center gap-5 flex-wrap">
  {links.map(({ label, href, icon }) => (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="group inline-flex items-center gap-2 text-[14px] font-mono text-(--text-secondary) hover:text-(--accent) transition-colors duration-150"
    >
      {icon === 'github' && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-(--text-tertiary) group-hover:text-(--accent) transition-colors"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 015.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.83 1.18 3.09 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/></svg>
      )}
      {icon === 'x' && (
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-(--text-tertiary) group-hover:text-(--accent) transition-colors"><path d="M18.244 2H21.5l-7.55 8.62L23 22h-6.812l-5.34-6.87L4.7 22H1.44l8.07-9.22L1 2h6.97l4.83 6.32L18.244 2zm-1.193 18h1.83L7.06 4H5.13l11.92 16z"/></svg>
      )}
      {icon === 'discord' && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-(--text-tertiary) group-hover:text-(--accent) transition-colors"><path d="M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
      )}
      {icon === 'youtube' && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-(--text-tertiary) group-hover:text-(--accent) transition-colors"><path d="M23.5 6.5a3 3 0 00-2.1-2.12C19.55 4 12 4 12 4s-7.55 0-9.4.38A3 3 0 00.5 6.5C.12 8.35.12 12 .12 12s0 3.65.38 5.5a3 3 0 002.1 2.12C4.45 20 12 20 12 20s7.55 0 9.4-.38a3 3 0 002.1-2.12c.38-1.85.38-5.5.38-5.5s0-3.65-.38-5.5zM9.6 15.6V8.4l6.4 3.6-6.4 3.6z"/></svg>
      )}
      {label}
