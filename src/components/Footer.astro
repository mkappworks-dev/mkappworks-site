---
const year = new Date().getFullYear();

const links = [
  { label: 'GitHub',  href: 'https://github.com/mkappworks-dev' },
  { label: 'X',       href: 'https://www.x.com/mkappworks' },
  { label: 'Discord', href: 'https://discord.gg/g2xKWJcF' },
  { label: 'YouTube', href: 'https://youtube.com/@mkappworks' },
];
---

<footer class="border-t border-[var(--border-subtle)] mt-20">
  <div class="max-w-[680px] mx-auto px-6 py-6 flex items-center justify-between flex-wrap gap-3">
    <span class="text-[13px] text-[var(--text-tertiary)] font-mono">
      © {year} mkappworks
    </span>
    <div class="flex items-center gap-4">
      {links.map(({ label, href }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[13px] text-[var(--text-tertiary)] font-mono hover:text-[var(--text-primary)] transition-colors duration-150"
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</footer>
