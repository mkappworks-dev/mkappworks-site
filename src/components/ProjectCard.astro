---
interface Props {
  slug: string;
  name: string;
  description: string;
  tags: string[];
  status: 'live' | 'beta' | 'wip';
  benchlabsApp?: boolean;
  /** If true, renders as a row (home page). If false, renders full card (/projects). */
  compact?: boolean;
}

const { slug, name, description, tags, status, benchlabsApp = false, compact = false } = Astro.props;

const statusStyles: Record<string, string> = {
  live: 'text-[#22c55e] bg-[var(--accent-subtle)]',
  beta: 'text-yellow-400 bg-yellow-500/10',
  wip:  'text-red-400 bg-red-500/10',
};
---

{compact ? (
  <a
    href={`/projects/${slug}/`}
    class="group block bg-[var(--surface)] px-5 py-4 hover:bg-[var(--surface-hover)] transition-colors duration-150"
  >
    <div class="flex items-center justify-between gap-4">
      <div class="min-w-0">
        <div class="flex items-center gap-2 mb-0.5">
          <span class="font-mono text-[14px] font-semibold text-[var(--text-primary)] tracking-tight group-hover:text-[var(--accent)] transition-colors">
            {name}
          </span>
          <span class={`font-mono text-[10px] px-1.5 py-0.5 rounded ${statusStyles[status]}`}>
            {status}
          </span>
        </div>
        {benchlabsApp && (
          <div class="font-mono text-[10px] text-[var(--text-tertiary)] mb-0.5">part of benchlabs</div>
        )}
        <div class="text-[12px] text-[var(--text-secondary)] leading-snug truncate">
          {description}
        </div>
      </div>
      <div class="flex items-center gap-1.5 shrink-0">
        {tags.slice(0, 2).map((tag) => (
          <span class="font-mono text-[10px] bg-[var(--bg)] text-[var(--text-tertiary)] px-2 py-0.5 rounded">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </a>
) : (
  <a
    href={`/projects/${slug}/`}
    class="group block border border-[var(--border)] bg-[var(--surface)] rounded-[10px] p-5 hover:bg-[var(--surface-hover)] transition-all duration-200"
  >
    <div class="flex items-start justify-between gap-3 mb-2">
      <h2 class="font-mono text-[16px] font-semibold text-[var(--text-primary)] tracking-tight group-hover:text-[var(--accent)] transition-colors">
        {name}
      </h2>
      <span class={`font-mono text-[11px] px-2 py-0.5 rounded shrink-0 ${statusStyles[status]}`}>
        {status}
      </span>
    </div>
    {benchlabsApp && (
      <div class="font-mono text-[11px] text-[var(--accent)] mb-2">// part of benchlabs</div>
    )}
    <p class="text-[14px] text-[var(--text-secondary)] leading-relaxed mb-3">
      {description}
    </p>
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="font-mono text-[12px] bg-[var(--bg)] text-[var(--text-tertiary)] px-2 py-0.5 rounded">
          {tag}
        </span>
      ))}
    </div>
  </a>
)}
