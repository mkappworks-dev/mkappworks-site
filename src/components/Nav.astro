---
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const links = [
  { href: '/projects', label: 'projects' },
  { href: '/blog', label: 'blog' },
  { href: '/about', label: 'about' },
];

---

<nav class="sticky top-0 z-10 bg-[var(--bg)] border-b border-[var(--border-subtle)]">
  <div class="max-w-[680px] mx-auto px-6 h-[60px] flex items-center justify-between gap-4">
    <!-- Left: logo + page links -->
    <div class="flex items-center gap-5">
      <a href="/" aria-label="mkappworks home">
        <img src="/favicon.svg" width="28" height="28" alt="mk!" class="rounded-[5px] ring-1 ring-[var(--border)]" />
      </a>
      <ul class="flex items-center gap-1 text-[13px] font-mono">
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'px-3 py-1.5 rounded-md transition-all duration-150',
                isActive(href)
                  ? 'text-[var(--accent)] bg-[var(--accent-subtle)]'
                  : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)]',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Right: theme toggle -->
    <ThemeToggle />
  </div>
</nav>
