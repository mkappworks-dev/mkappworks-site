---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const benchlabsProjects = allProjects.filter((p) => p.data.benchlabsApp);
const otherProjects = allProjects.filter((p) => !p.data.benchlabsApp);
---

<BaseLayout title="Projects" description="Open-source tools and experiments.">
  <div class="max-w-170 mx-auto px-6 py-12">
    <div class="font-mono text-[11px] tracking-[2px] text-(--accent) uppercase mb-4">
      // projects
    </div>
    <h1 class="font-mono text-[28px] font-semibold text-(--text-primary) tracking-tight mb-2">
      Projects
    </h1>
    <p class="text-[15px] text-(--text-secondary) mb-10">
      Open-source tools and experiments.
    </p>

    <div class="font-mono text-[11px] tracking-[2px] text-(--text-tertiary) uppercase mb-3">
      // benchlabs
    </div>
    <div class="flex flex-col gap-3">
      {benchlabsProjects.map((project) => (
        <ProjectCard
          slug={project.id}
          name={project.data.name}
          description={project.data.description}
          tags={project.data.tags}
          status={project.data.status}
          benchlabsApp={project.data.benchlabsApp}
          compact={false}
        />
      ))}
    </div>

    <div class="font-mono text-[11px] tracking-[2px] text-(--text-tertiary) uppercase mt-10 mb-3">
      // infra
    </div>
    <div class="flex flex-col gap-3">
      {otherProjects.map((project) => (
        <ProjectCard
          slug={project.id}
          name={project.data.name}
          description={project.data.description}
          tags={project.data.tags}
          status={project.data.status}
          benchlabsApp={project.data.benchlabsApp}
          compact={false}
        />
      ))}
    </div>
  </div>
</BaseLayout>
