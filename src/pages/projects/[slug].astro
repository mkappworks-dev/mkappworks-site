---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpecSheet from '../../components/SpecSheet.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';

export const getStaticPaths: GetStaticPaths = async () => {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
};

const { project } = Astro.props as { project: CollectionEntry<'projects'> };
const { Content } = await render(project);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((p) => p.data.tags.includes(project.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const statusLabels = { live: 'live', beta: 'beta', wip: 'wip' } as const;
const statusStyles: Record<'live' | 'beta' | 'wip', string> = {
  live: 'text-[#22c55e] bg-[var(--accent-subtle)]',
  beta: 'text-yellow-400 bg-yellow-500/10',
  wip:  'text-red-400 bg-red-500/10',
};

const rows: { label: string; html: string }[] = [
  {
    label: 'status',
    html: (() => {
      const status = project.data.status;
      return `<span class="inline-block px-2 py-0.5 rounded text-[12px] ${statusStyles[status]}">${statusLabels[status]}</span>`;
    })(),
  },
];

if (project.data.benchlabsApp) {
  rows.push({ label: 'part of', html: 'benchlabs' });
}

if (project.data.tags?.length) {
  rows.push({ label: 'stack', html: project.data.tags.join(' · ') });
}

const linkParts: string[] = [];
if (project.data.github) {
  linkParts.push(`<a href="${project.data.github}" target="_blank" rel="noopener noreferrer" class="text-[var(--accent)] hover:opacity-80">github ↗</a>`);
}
if (project.data.url) {
  linkParts.push(`<a href="${project.data.url}" target="_blank" rel="noopener noreferrer" class="text-[var(--accent)] hover:opacity-80">live site ↗</a>`);
}
if (linkParts.length > 0) {
  rows.push({ label: 'links', html: linkParts.join(' &nbsp; ') });
}
---

<BaseLayout title={project.data.name} description={project.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://mkappworks.com' },
      { '@type': 'ListItem', position: 2, name: 'Projects', item: 'https://mkappworks.com/projects' },
      { '@type': 'ListItem', position: 3, name: project.data.name },
    ],
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: project.data.name,
    description: project.data.description,
    url: project.data.url ?? `https://mkappworks.com/projects/${project.id}`,
    keywords: project.data.tags?.join(', '),
    author: { '@type': 'Person', name: 'mk', url: 'https://mkappworks.com' },
    ...(project.data.status !== 'wip' && { applicationCategory: 'DeveloperApplication' }),
  })} />
  <article class="max-w-[680px] mx-auto px-6 py-12">
    <!-- Back -->
    <a
      href="/projects/"
      class="inline-flex items-center gap-1 text-[13px] font-mono text-[var(--text-tertiary)] hover:text-[var(--accent)] transition-colors mb-10"
    >
      ← back to projects
    </a>

    <!-- Header -->
    <header class="mb-8">
      {project.data.icon && (
        <img
          src={project.data.icon}
          alt={`${project.data.name} icon`}
          width="72"
          height="72"
          class="rounded-[16px] mb-5"
        />
      )}
      <h1 class="font-mono text-[28px] font-semibold text-[var(--text-primary)] tracking-tight mb-3">
        {project.data.name}
      </h1>
      <p class="text-[15px] text-[var(--text-secondary)] leading-relaxed max-w-[520px] mb-6">
        {project.data.description}
      </p>
      <SpecSheet rows={rows} />
    </header>

    <!-- Body -->
    <div class="prose">
      <Content />
    </div>

    <!-- Related posts -->
    {relatedPosts.length > 0 && (
      <section class="mt-14 pt-8 border-t border-[var(--border-subtle)]">
        <div class="font-mono text-[11px] tracking-[2px] text-[var(--accent)] uppercase mb-4">
          // related posts
        </div>
        <div>
          {relatedPosts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="group flex items-center justify-between gap-4 py-2 border-b border-[var(--border-subtle)] last:border-0"
            >
              <div class="font-mono text-[14px] text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors">
                {post.data.title}
              </div>
              <time class="font-mono text-[12px] text-[var(--text-tertiary)] shrink-0">
                {post.data.date.toISOString().slice(0, 10)}
              </time>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
