---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostPreview from '../components/PostPreview.astro';
import { getCollection } from 'astro:content';
import { getMinutesRead } from '../utils/reading-time';

const allProjects = await getCollection('projects');
const benchlabsProjects = allProjects.filter((p) => p.data.benchlabsApp);
const infraProjects = allProjects.filter(
  (p) => !p.data.benchlabsApp && p.data.tags.includes('infra'),
);
const productProjects = allProjects.filter(
  (p) => !p.data.benchlabsApp && !p.data.tags.includes('infra'),
);
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Home"
  description="Developer building tools for the open web. Writing about dev tooling, open source, and the craft of shipping software."
>
  <!-- Hero -->
  <section class="max-w-[680px] mx-auto px-6 pt-12 pb-12">
    <div class="font-mono text-[11px] tracking-[2px] text-(--accent) uppercase mb-5">
      // builder · open source
    </div>
    <h1 class="font-mono text-[clamp(28px,5vw,32px)] font-semibold text-(--text-primary) tracking-tight leading-[1.2] mb-5">
      mkappworks
    </h1>
    <p class="text-[16px] text-(--text-secondary) leading-[1.65] mb-8">
      I build open source projects at the intersection of dev tooling, games, and infrastructure.
      Writing about system design and algorithms along the way.
    </p>
    <SocialLinks />
  </section>

  <div class="max-w-[680px] mx-auto px-6 border-t border-(--border-subtle)"></div>

  <!-- Projects -->
  <section class="max-w-[680px] mx-auto px-6 py-12">
    <div class="font-mono text-[11px] tracking-[2px] text-(--accent) uppercase mb-6">
      // projects
    </div>
    <div class="font-mono text-[11px] tracking-[2px] text-(--text-tertiary) uppercase mb-3">
      // desktop
    </div>
    <div class="border border-(--border) rounded-lg overflow-hidden flex flex-col gap-px bg-(--border)">
      {benchlabsProjects.map((project) => (
        <ProjectCard
          slug={project.id}
          name={project.data.name}
          description={project.data.description}
          tags={project.data.tags}
          status={project.data.status}
          benchlabsApp={project.data.benchlabsApp}
          compact={true}
        />
      ))}
    </div>

    <div class="font-mono text-[11px] tracking-[2px] text-(--text-tertiary) uppercase mt-8 mb-3">
      // web
    </div>
    <div class="border border-(--border) rounded-lg overflow-hidden flex flex-col gap-px bg-(--border)">
      {productProjects.map((project) => (
        <ProjectCard
          slug={project.id}
          name={project.data.name}
          description={project.data.description}
          tags={project.data.tags}
          status={project.data.status}
          benchlabsApp={project.data.benchlabsApp}
          compact={true}
        />
      ))}
    </div>

    <div class="font-mono text-[11px] tracking-[2px] text-(--text-tertiary) uppercase mt-8 mb-3">
      // infra
    </div>
    <div class="border border-(--border) rounded-lg overflow-hidden flex flex-col gap-px bg-(--border)">
      {infraProjects.map((project) => (
        <ProjectCard
          slug={project.id}
          name={project.data.name}
          description={project.data.description}
          tags={project.data.tags}
          status={project.data.status}
          benchlabsApp={project.data.benchlabsApp}
          compact={true}
        />
      ))}
    </div>
    <a
      href="/projects/"
      class="inline-flex items-center gap-1 mt-4 text-[13px] font-mono font-medium text-(--accent) hover:gap-2 transition-all duration-150"
    >
      all projects →
    </a>
  </section>
   {latestPosts.length > 0 && (
    <>
      <div class="max-w-[680px] mx-auto px-6 border-t border-(--border-subtle)"></div>

      <!-- Writing -->
      <section class="max-w-[680px] mx-auto px-6 py-12">
        <div class="font-mono text-[11px] tracking-[2px] text-(--accent) uppercase mb-6">
          // writing
        </div>
        <div>
          {latestPosts.map((post) => (
            <PostPreview
              slug={post.id}
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
              minutesRead={getMinutesRead(post.body)}
            />
          ))}
        </div>
        <a
          href="/blog/"
          class="inline-flex items-center gap-1 mt-4 text-[13px] font-mono font-medium text-(--accent) hover:gap-2 transition-all duration-150"
        >
          all posts →
        </a>
      </section>
    </>
  )}
</BaseLayout>
