---
import BaseLayout from '../layouts/BaseLayout.astro';

const building = [
  { name: 'BenchLabs', href: 'https://benchlabs.app', external: true,  desc: 'Local-first AI dev tools, built with Flutter.' },
  { name: 'Cloudzilla', href: 'https://cloudzilla.dev', external: true, desc: 'Self-hosted, single-binary Git forge in Go.' },
];

const stack = [
  { label: 'languages', items: 'TypeScript, Go, Python, Dart, Java' },
  { label: 'frontend',  items: 'Astro, ReactJS, SolidJS, Flutter, Tailwind' },
  { label: 'backend',   items: 'NodeJS, Spring Boot, Postgres, Redis' },
  { label: 'tools',     items: 'Git, Docker, GitHub Actions, Vercel' },
];

const connect = [
  { label: 'github',  href: 'https://github.com/mkappworks-dev' },
  { label: 'x',       href: 'https://x.com/mkappworks' },
  { label: 'discord', href: 'https://discord.gg/g2xKWJcF' },
  { label: 'youtube', href: 'https://youtube.com/@mkappworks' },
];
---

<BaseLayout title="About" description="About mkappworks.">
  <div class="max-w-170 mx-auto px-6 py-12">
    <div class="font-mono text-[11px] tracking-[2px] text-(--accent) uppercase mb-4">
      // about
    </div>
    <h1 class="font-mono text-[28px] font-semibold text-(--text-primary) tracking-tight mb-8">
      About
    </h1>

    <div class="text-[15px] text-(--text-secondary) leading-[1.7] space-y-4 mb-10">
      <p>
        I build developer tools — mostly local-first, mostly open source. I write about dev tooling,
        system design, and shipping software.
      </p>
      <p>
        Right now that means two things: <a href="https://benchlabs.app" target="_blank" rel="noopener noreferrer" class="text-(--accent) border-b border-[rgba(34,197,94,0.4)] hover:opacity-80 transition-opacity">BenchLabs</a>,
        a suite of local-first AI dev tools, and <a href="https://cloudzilla.dev" class="text-(--accent) border-b border-[rgba(34,197,94,0.4)] hover:opacity-80 transition-opacity">Cloudzilla</a>,
        a self-hosted Git forge that ships as a single binary.
      </p>
      <p>
        Most of what I build is open source. The blog has the long-form thinking; GitHub has the code.
      </p>
    </div>

    <!-- Building -->
    <div class="font-mono text-[11px] tracking-[2px] text-(--accent) uppercase mb-4">
      // building
    </div>
    <div class="mb-12 space-y-3">
      {building.map(({ name, href, external, desc }) => (
        <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-3">
          <a
            href={href}
            {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class="font-mono text-[14px] text-(--accent) hover:opacity-80 transition-opacity shrink-0 sm:w-27.5"
          >
            {name}{external && ' ↗'}
          </a>
          <span class="text-[14px] text-(--text-secondary) leading-snug">{desc}</span>
        </div>
      ))}
    </div>

    <!-- Stack -->
    <div class="font-mono text-[11px] tracking-[2px] text-(--accent) uppercase mb-4">
      // stack
    </div>
    <dl class="stack-list font-mono text-[13px] mb-12 grid gap-y-1.5 gap-x-3">
      {stack.map((row) => (
        <>
          <dt class="text-(--accent)">{row.label}</dt>
          <dd class="text-(--text-secondary) m-0" style={{ fontFamily: 'Inter, system-ui, sans-serif' }}>{row.items}</dd>
        </>
      ))}
    </dl>

    <!-- Connect -->
    <div class="font-mono text-[11px] tracking-[2px] text-(--accent) uppercase mb-4">
      // connect
    </div>
    <div class="flex flex-wrap gap-x-5 gap-y-2 font-mono text-[14px]">
      {connect.map(({ label, href }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-(--accent) hover:opacity-80 transition-opacity"
        >
          {label} ↗
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .stack-list {
    grid-template-columns: 100px 1fr;
  }
  @media (max-width: 480px) {
    .stack-list {
      grid-template-columns: 1fr;
    }
    .stack-list dt { margin-top: 0.5rem; }
    .stack-list dt:first-child { margin-top: 0; }
  }
</style>
